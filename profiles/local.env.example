# Optional machine-local setup overrides.
# Copy to one of:
# - profiles/local.env
# - ~/.config/dot/local.env
#
# Both locations are local-only. Do not commit real values.

DOT_PROFILE=profile1
TOOLS_HOME="$HOME/.tools"

# Optional profile-specific extra skill source folders.
# Use colon-separated paths when a profile should link more than one source.
# DOT_SKILLS_PROFILE1="$HOME/path/to/profile1/skills"
# DOT_SKILLS_PROFILE2="$HOME/path/to/profile2/skills"

# Optional overrides. Leave commented to use profile defaults.
# DOT_ENABLE_DIA=0
# DOT_ENABLE_ONEPASSWORD=1
# DOT_ENABLE_SYSTEM_EXTENSIONS=1
# CODEX_NODE_REPL_ENV_FILE="$HOME/.config/dot/codex-node-repl.env.toml"
