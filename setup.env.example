# Machine-local setup values.
# Copy this file to setup.env, fill the blanks, then run scripts/setup.sh.
# setup.env is ignored and should not be committed.
#
# The example is first-pass safe: it can run before Git signing keys and
# 1Password SSH items exist. After those are ready, set the Git and 1Password
# feature toggles to 1 and run setup again.

# Ordered Homebrew layers. Keep base as the shared "install everywhere" layer.
DOT_BREWFILES="homebrew/Brewfile.primary"

# Login shell preference. Use fish, zsh, none, or an absolute shell path.
# Zsh remains configured even when Fish is the default login shell.
DOT_DEFAULT_SHELL=fish

# Tool homes.
TOOLS_HOME="$HOME/.tools"
CODEX_NODE_REPL_ENV_FILE="$HOME/.config/dot/codex-node-repl.env.toml"
DOT_CODEX_NOTIFY_COMMAND="$HOME/.codex/computer-use/Codex Computer Use.app/Contents/SharedSupport/SkyComputerUseClient.app/Contents/MacOS/SkyComputerUseClient"

# Local navigation shortcuts. Leave blank on machines that do not have these.
DOT_CLOUDSTORAGE_HOME="$HOME/Library/CloudStorage"
DOT_DROPBOX_HOME=""
DOT_VAULT_HOME=""
DOT_GDRIVE_HOME=""

# Optional extra skill roots, colon-separated.
# Example: DOT_SKILL_SOURCES="$HOME/path/to/skills:$HOME/other/skills"
DOT_SKILL_SOURCES=""
DOT_PRUNE_EXTRA_SKILLS=0

# Feature toggles. Use 1 for enabled and 0 for disabled.
DOT_ENABLE_DIA=1
DOT_ENABLE_ONEPASSWORD=0
DOT_ENABLE_SYSTEM_EXTENSIONS=1
DOT_ENABLE_CODEX_CONFIG=1
DOT_ENABLE_GIT_CONFIG=0

# Git identity and SSH signing.
DOT_GIT_USER_NAME=""
DOT_GIT_USER_EMAIL=""
DOT_GIT_SIGNING_KEY=""
DOT_GIT_ALLOWED_SIGNERS_FILE="$HOME/.config/git/allowed-signers"

# 1Password SSH agent config.
DOT_OP_VAULT=""
DOT_OP_SSH_AUTH_ITEM=""
DOT_OP_SSH_SIGN_ITEM=""

# Dia CDP / agent-browser.
DOT_DIA_APP="/Applications/Dia.app"
DOT_DIA_LOG_DIR="$HOME/Library/Logs"
AGENT_BROWSER_DIA_PORT=9222
