{
	"agent_servers": {
		"codex-acp": {
			"type": "registry"
		},
		"claude-acp": {
			"type": "registry"
		}
	},
	"project_panel": {
		"dock": "right"
	},
	"collaboration_panel": {
		"dock": "right"
	},
	"agent": {
		"dock": "left",
		"favorite_models": [],
		"model_parameters": []
	},
	"theme": { "mode": "system", "light": "Github Plus Light", "dark": "Github Plus Dark" },
	"ui_font_size": 15,
	"buffer_font_size": 12,
	"buffer_font_family": "Fira Code Retina",
	"icon_theme": "Zed (Default)",

	"git_panel": { "sort_by_path": false, "dock": "right" },
	"outline_panel": { "dock": "right" },
	"minimap": { "show": "always" },

	"show_whitespaces": "all",
	"format_on_save": "on",
	"code_actions_on_format": {
		"source.fixAll.biome": true,
		"source.organizeImports.biome": true
	},
	"formatter": { "language_server": { "name": "biome" } },

	"terminal": {
		"font_family": "SF Mono",
		"working_directory": "current_project_directory"
	},

	"features": { "edit_prediction_provider": "zed" },
	"telemetry": { "diagnostics": false, "metrics": false },

	"lsp": {
		"biome": { "settings": { "require_config_file": true } }
	},

	"languages": {
		"JavaScript": { "formatter": { "language_server": { "name": "biome" } } },
		"TypeScript": { "formatter": { "language_server": { "name": "biome" } } },
		"TSX": { "formatter": { "language_server": { "name": "biome" } } },
		"JSON": { "formatter": { "language_server": { "name": "biome" } } },
		"JSONC": { "formatter": { "language_server": { "name": "biome" } } },
		"CSS": { "formatter": { "language_server": { "name": "biome" } } },
		"Markdown": { "formatter": { "external": { "command": "/Users/han/Git/dot/scripts/markdown.sh", "arguments": ["{buffer_path}"] } } },
		"Python": { "language_servers": ["ruff"], "formatter": { "language_server": { "name": "ruff" } } }
	}
}
