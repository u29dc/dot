# ~/.zprofile - Executed for login shells.

# Add Homebrew to your PATH
# This line is required for Homebrew to work correctly on Apple Silicon Macs.
if [ -x /opt/homebrew/bin/brew ]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
fi

# >>> Codex installer >>>
if [ -d "$HOME/.codex/packages/standalone/bin" ]; then
    export PATH="$HOME/.codex/packages/standalone/bin:$PATH"
fi
# <<< Codex installer <<<
