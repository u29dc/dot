# FUNCTIONS
# Custom shell functions for enhanced functionality
# ------------------------------------------------------------------------------

# Tool launchers
:ash() { "$ASH_HOME/ash" "$@"; }
:buf() { "$BUF_HOME/buf" "$@"; }
:cho() { "$CHO_HOME/cho" "$@"; }
:fin() { "$FIN_HOME/fin" "$@"; }
:kai() { "$KAI_HOME/kai" "$@"; }
:let() { "$LET_HOME/let" "$@"; }
:pdf() { "$PDF_HOME/pdf" "$@"; }
:tab() { "$TAB_HOME/tab" "$@"; }
:tao() { "$TAO_HOME/tao" "$@"; }

# AI assistant wrappers
cc() {
    if [[ "$1" == "allow" || "$1" == "auto" ]]; then
        shift
        claude --enable-auto-mode --permission-mode auto "$@"
    else
        claude --enable-auto-mode "$@"
    fi
}

# Auto-trust working paths under ~/Git and ~/Library/CloudStorage/Dropbox.
_codex_auto_trust_path() {
    local codex_home cfg candidate trust_target
    codex_home="${CODEX_HOME:-$HOME/.codex}"
    cfg="$codex_home/config.toml"

    if [[ -n "$1" ]]; then
        candidate="$(cd "$1" 2>/dev/null && pwd -P)" || return 0
    else
        candidate="$(pwd -P 2>/dev/null || pwd)"
    fi

    case "$candidate" in
        "$HOME/Git" | "$HOME/Git/"* | "$HOME/Library/CloudStorage/Dropbox" | "$HOME/Library/CloudStorage/Dropbox/"*)
            ;;
        *)
            return 0
            ;;
    esac

    [[ -f "$cfg" ]] || return 0

    if git -C "$candidate" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        trust_target="$(git -C "$candidate" rev-parse --show-toplevel 2>/dev/null)" || trust_target="$candidate"
    else
        # Non-git folders still get trusted to avoid repeated prompt friction.
        trust_target="$candidate"
    fi

    [[ -n "$trust_target" ]] || return 0

    if command -v rg >/dev/null 2>&1; then
        rg -Fq "[projects.\"$trust_target\"]" "$cfg" && return 0
    else
        grep -Fq "[projects.\"$trust_target\"]" "$cfg" && return 0
    fi

    {
        printf '\n[projects."%s"]\n' "$trust_target"
        printf 'trust_level = "trusted"\n'
    } >> "$cfg"
}

# Resolve the active project root for Codex session reuse.
_codex_project_root() {
    local candidate

    if [[ -n "$1" ]]; then
        candidate="$(cd "$1" 2>/dev/null && pwd -P)" || return 1
    else
        candidate="$(pwd -P 2>/dev/null || pwd)"
    fi

    if git -C "$candidate" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        git -C "$candidate" rev-parse --show-toplevel 2>/dev/null || print -r -- "$candidate"
    else
        print -r -- "$candidate"
    fi
}

# Resolve the latest saved Codex session id for a project root.
_codex_latest_session_id() {
    local project_root codex_home sessions_dir session_file session_id
    project_root="$1"

    [[ -n "$project_root" ]] || return 1

    codex_home="${CODEX_HOME:-$HOME/.codex}"
    sessions_dir="$codex_home/sessions"
    [[ -d "$sessions_dir" ]] || return 1

    if command -v rg >/dev/null 2>&1; then
        session_file="$(
            rg -F -l --glob '*.jsonl' "\"cwd\":\"$project_root\"" "$sessions_dir" 2>/dev/null \
                | LC_ALL=C sort \
                | tail -n 1
        )"
    else
        session_file="$(
            find "$sessions_dir" -type f -name '*.jsonl' -print 2>/dev/null \
                | LC_ALL=C sort \
                | while IFS= read -r candidate; do
                    grep -Fq "\"cwd\":\"$project_root\"" "$candidate" && printf '%s\n' "$candidate"
                done \
                | tail -n 1
        )"
    fi

    [[ -n "$session_file" && -f "$session_file" ]] || return 1

    session_id="$(sed -nE '1s/.*"id":"([^"]+)".*/\1/p' "$session_file")"
    [[ -n "$session_id" ]] || return 1

    print -r -- "$session_id"
}

# Ensure `codex` resolves to the official CLI binary after re-sourcing this file.
unfunction codex 2>/dev/null

# `co` keeps the opinionated Codex workflow while `codex` stays official.
co() {
    local arg project_root session_id target_dir
    local -a args prefix_args rest_args

    args=("$@")
    prefix_args=()
    rest_args=()

    local i=1

    while (( i <= $#args )); do
        arg="${args[i]}"

        case "$arg" in
            -C | --cd)
                if (( i == $#args )); then
                    command codex "$@"
                    return
                fi

                target_dir="${args[i + 1]}"
                (( i += 2 ))
                ;;
            --cd=*)
                target_dir="${arg#--cd=}"
                (( i += 1 ))
                ;;
            -c | -m | -p | -s | -a | -i)
                if (( i == $#args )); then
                    command codex "$@"
                    return
                fi

                prefix_args+=("$arg" "${args[i + 1]}")
                (( i += 2 ))
                ;;
            --config | --enable | --disable | --remote | --remote-auth-token-env | --local-provider | --profile | --sandbox | --ask-for-approval | --image | --model | --add-dir)
                if (( i == $#args )); then
                    command codex "$@"
                    return
                fi

                prefix_args+=("$arg" "${args[i + 1]}")
                (( i += 2 ))
                ;;
            --config=* | --enable=* | --disable=* | --remote=* | --remote-auth-token-env=* | --local-provider=* | --profile=* | --sandbox=* | --ask-for-approval=* | --image=* | --model=* | --add-dir=*)
                prefix_args+=("$arg")
                (( i += 1 ))
                ;;
            --oss | --full-auto | --dangerously-bypass-approvals-and-sandbox | --search | --no-alt-screen)
                prefix_args+=("$arg")
                (( i += 1 ))
                ;;
            -h | --help | -V | --version)
                command codex "$@"
                return
                ;;
            -*)
                command codex "$@"
                return
                ;;
            *)
                rest_args=("${(@)args[$i,-1]}")
                break
                ;;
        esac
    done

    if [[ -n "$target_dir" ]]; then
        project_root="$(_codex_project_root "$target_dir" 2>/dev/null)" || project_root=""
    else
        project_root="$(_codex_project_root 2>/dev/null)" || project_root=""
    fi

    [[ -n "$project_root" ]] && _codex_auto_trust_path "$project_root"

    if (( ${#rest_args} == 0 )); then
        session_id="$(_codex_latest_session_id "$project_root" 2>/dev/null)" || session_id=""

        if [[ -n "$project_root" && -n "$session_id" ]]; then
            command codex "${prefix_args[@]}" -C "$project_root" resume "$session_id"
        elif [[ -n "$project_root" ]]; then
            command codex "${prefix_args[@]}" -C "$project_root"
        else
            command codex "${prefix_args[@]}"
        fi
        return
    fi

    case "${rest_args[1]}" in
        exec | e | review | login | logout | mcp | mcp-server | app-server | app | completion | sandbox | debug | apply | a | cloud | exec-server | features | help)
            command codex "$@"
            ;;
        new)
            if [[ -n "$project_root" ]]; then
                command codex "${prefix_args[@]}" -C "$project_root" "${(@)rest_args[2,-1]}"
            else
                command codex "${prefix_args[@]}" "${(@)rest_args[2,-1]}"
            fi
            ;;
        resume | fork)
            if [[ "${rest_args[2]}" == "--last" && ${#rest_args} -gt 2 && "${rest_args[3]}" != -* ]]; then
                session_id="$(_codex_latest_session_id "$project_root" 2>/dev/null)" || session_id=""
            else
                session_id=""
            fi

            if [[ -n "$project_root" && -n "$session_id" ]]; then
                command codex "${prefix_args[@]}" -C "$project_root" "${rest_args[1]}" "$session_id" "${(@)rest_args[3,-1]}"
            elif [[ -n "$project_root" ]]; then
                command codex "${prefix_args[@]}" -C "$project_root" "${rest_args[@]}"
            else
                command codex "${prefix_args[@]}" "${rest_args[@]}"
            fi
            ;;
        *)
            session_id="$(_codex_latest_session_id "$project_root" 2>/dev/null)" || session_id=""

            if [[ -n "$project_root" && -n "$session_id" ]]; then
                command codex "${prefix_args[@]}" -C "$project_root" resume "$session_id" "${rest_args[@]}"
            elif [[ -n "$project_root" ]]; then
                command codex "${prefix_args[@]}" -C "$project_root" "${rest_args[@]}"
            else
                command codex "${prefix_args[@]}" "${rest_args[@]}"
            fi
            ;;
    esac
}

# Repo maintenance helpers
_local_biome_info() {
    (
        cd "$1" || exit 1
        bun --no-install --eval '
            import path from "node:path";
            import { createRequire } from "node:module";

            const require = createRequire(process.cwd() + "/noop.js");

            try {
                const pkgPath = require.resolve("@biomejs/biome/package.json");
                const pkg = require(pkgPath);
                const binRel = typeof pkg.bin === "string" ? pkg.bin : pkg.bin?.biome;

                if (!pkg.version || !binRel) {
                    process.exit(1);
                }

                console.log(`${pkg.version}\t${path.resolve(path.dirname(pkgPath), binRel)}`);
            } catch {
                process.exit(1);
            }
        '
    )
}

bup() {
    local repo_root=""
    local biome_info=""
    local biome_before=""
    local biome_after=""
    local biome_bin=""

    if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        repo_root="$(git rev-parse --show-toplevel 2>/dev/null)" || repo_root=""
    fi

    if [[ -z "$repo_root" ]]; then
        repo_root="$PWD"
    fi

    if [[ -f "$repo_root/biome.json" || -f "$repo_root/biome.jsonc" ]]; then
        biome_info="$(_local_biome_info "$repo_root" 2>/dev/null)" || biome_info=""

        if [[ -n "$biome_info" ]]; then
            IFS=$'\t' read -r biome_before biome_bin <<< "$biome_info"
        fi
    fi

    bun update --latest || return $?

    if [[ -n "$biome_before" ]]; then
        biome_info="$(_local_biome_info "$repo_root" 2>/dev/null)" || biome_info=""

        if [[ -n "$biome_info" ]]; then
            IFS=$'\t' read -r biome_after biome_bin <<< "$biome_info"
        fi
    fi

    if [[ -n "$biome_before" && -n "$biome_after" && "$biome_before" != "$biome_after" && -x "$biome_bin" ]]; then
        (
            cd "$repo_root" || exit 1
            "$biome_bin" migrate --write
        )
    fi
}

# CLI wrappers
eza() {
    if [[ "$*" == *"--tree"* ]] || [[ "$*" == *"-T"* ]]; then
        command eza --icons --git-ignore -I "$EZA_DEFAULT_IGNORE" "$@"
    else
        command eza --icons "$@"
    fi
}

zed() {
    if [ $# -eq 0 ]; then
        command zed .
    else
        command zed "$@"
    fi
}

